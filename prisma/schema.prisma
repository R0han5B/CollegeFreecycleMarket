generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mongodb"
  url      = env("DATABASE_URL")
}

model User {
  id            String   @id @default(auto()) @map("_id") @db.ObjectId
  email         String   @unique
  password      String
  name          String?
  phone         String?
  isAdmin       Boolean  @default(false)
  credits       Int      @default(100)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  items         Item[]
  sentMessages  Message[] @relation("SentMessages")
  receivedMessages Message[] @relation("ReceivedMessages")
  sentRatings   Rating[] @relation("RatingsGiven")
  receivedRatings Rating[] @relation("RatingsReceived")
  paymentsAsBuyer Payment[] @relation("BuyerPayments")
  paymentsAsSeller Payment[] @relation("SellerPayments")
  watchlist     Watchlist[]
  reports       Report[]
}

model Category {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  name        String   @unique
  description String?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  items       Item[]
}

model Item {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  title       String
  description String
  tags        String[] @default([])
  price       Int
  condition   String
  image       String?
  images      String[] @default([])
  isFeatured  Boolean  @default(false)
  isSold      Boolean  @default(false)

  categoryId  String   @db.ObjectId
  sellerId    String   @db.ObjectId

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  category    Category @relation(fields: [categoryId], references: [id])
  seller      User     @relation(fields: [sellerId], references: [id])

  messages    Message[]
  ratings     Rating[]
  watchlist   Watchlist[]
  reports     Report[]
  payments    Payment[]
}

model Message {
  id         String   @id @default(auto()) @map("_id") @db.ObjectId
  content    String?
  senderId   String   @db.ObjectId
  receiverId String   @db.ObjectId
  itemId     String   @db.ObjectId
  imageUrl   String?
  read       Boolean  @default(false)
  createdAt  DateTime @default(now())

  sender     User     @relation("SentMessages", fields: [senderId], references: [id])
  receiver   User     @relation("ReceivedMessages", fields: [receiverId], references: [id])
  item       Item     @relation(fields: [itemId], references: [id])
}

model Rating {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  rating    Int
  comment   String?
  raterId   String   @db.ObjectId
  ratedId   String   @db.ObjectId
  itemId    String   @db.ObjectId
  createdAt DateTime @default(now())

  rater     User     @relation("RatingsGiven", fields: [raterId], references: [id])
  rated     User     @relation("RatingsReceived", fields: [ratedId], references: [id])
  item      Item     @relation(fields: [itemId], references: [id])
}

model Payment {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  amount    Int
  buyerId   String   @db.ObjectId
  sellerId  String   @db.ObjectId
  itemId    String   @db.ObjectId
  status    String   @default("pending")
  createdAt DateTime @default(now())

  buyer     User     @relation("BuyerPayments", fields: [buyerId], references: [id])
  seller    User     @relation("SellerPayments", fields: [sellerId], references: [id])
  item      Item     @relation(fields: [itemId], references: [id])
}

model Watchlist {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  userId    String   @db.ObjectId
  itemId    String   @db.ObjectId
  createdAt DateTime @default(now())

  user      User     @relation(fields: [userId], references: [id])
  item      Item     @relation(fields: [itemId], references: [id])

  @@unique([userId, itemId])
}

model Report {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  reason    String
  status    String   @default("pending")
  userId    String   @db.ObjectId
  itemId    String   @db.ObjectId
  createdAt DateTime @default(now())

  user      User     @relation(fields: [userId], references: [id])
  item      Item     @relation(fields: [itemId], references: [id])
}
